# Copy to .env.local (gitignored) and fill in for local dev.
# Keep in sync with REQUIRED_KEYS in src/constants/env.ts and every eas.json
# build profile's `env` block.

EXPO_PUBLIC_API_URL=http://localhost:8080
EXPO_PUBLIC_USE_MOCKS=true

# Optional
# EXPO_PUBLIC_SENTRY_DSN=
# EXPO_PUBLIC_OAUTH_ISSUER_URL=
# EXPO_PUBLIC_OAUTH_CLIENT_ID=
